#version 450
layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer InputBlock {
    float data[];
} input_buf;

layout(set = 0, binding = 1) buffer OutputBlock {
    float data[];
} output_buf;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    output_buf.data[idx] = input_buf.data[idx] * 2.0;
}
